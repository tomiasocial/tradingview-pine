// ============================================================
// Full Indicator Suite (All-in-One) | v1.6.0 | 2026-05-07
// Author: Project Owner
// Description: Trend Candles + S/D Zones + Trendlines (convergence-only)
// Changes v1.6.0: Module 3 → diagonal lines connecting last 2 highs/lows,
//                 drawn ONLY when lines converge or are parallel (triangle/channel).
//                 Diverging/fanning patterns are suppressed entirely.
// ============================================================

//@version=6
indicator("Full Suite [Trend + Zone + Lines]", overlay=true, max_bars_back=500)

// ═══════════════════════════════════════════════════════════
//  MASTER TOGGLES
// ═══════════════════════════════════════════════════════════
enableTrend = input.bool(true, "① Trend Candles ON",  group="═ Master Toggles ═")
enableZone  = input.bool(true, "② S/D Zones ON",      group="═ Master Toggles ═")
enableLines = input.bool(true, "③ Trendlines ON",     group="═ Master Toggles ═")

// ═══════════════════════════════════════════════════════════
//  MODULE 1 — TREND CANDLES
// ═══════════════════════════════════════════════════════════
tc_atrPeriod   = input.int(10,    "ATR Period",        minval=3,   maxval=50,            group="① Trend Candles")
tc_atrMult     = input.float(2.0, "ATR Multiplier",    minval=0.5, maxval=5.0, step=0.1, group="① Trend Candles")
tc_confirmBars = input.int(1,     "Confirmation Bars", minval=1,   maxval=5,             group="① Trend Candles")
tc_colorUp     = input.color(#00C853, "Uptrend Color",                                   group="① Trend Candles")
tc_colorDown   = input.color(#FF1744, "Downtrend Color",                                 group="① Trend Candles")
tc_showST      = input.bool(true,     "Show Supertrend Line",                            group="① Trend Candles")

[stLine, stDir] = ta.supertrend(tc_atrMult, tc_atrPeriod)

var int tc_state = 0
var int tc_cnt   = 0
tc_raw = stDir == -1 ? 1 : -1

if tc_raw == tc_state
    tc_cnt := tc_cnt + 1
else
    if tc_cnt >= tc_confirmBars
        tc_state := tc_raw
        tc_cnt   := 1
    else
        tc_cnt := tc_cnt + 1

if tc_state == 0
    tc_state := tc_raw
    tc_cnt   := 1

tc_up    = tc_state == 1
tc_color = tc_up ? tc_colorUp : tc_colorDown

barcolor(enableTrend ? tc_color : na)

plot(enableTrend and tc_showST ? stLine : na, "Supertrend",
     color     = tc_up ? color.new(tc_colorUp, 60) : color.new(tc_colorDown, 60),
     linewidth = 2)

alertcondition(enableTrend and tc_up and not tc_up[1],  "① Trend → UP",   "Suite: Trend → UP")
alertcondition(enableTrend and not tc_up and tc_up[1],  "① Trend → DOWN", "Suite: Trend → DOWN")

// ═══════════════════════════════════════════════════════════
//  MODULE 2 — S/D ZONES
//  Resistance box = thin band at TOP of detected range
//  Support box    = thin band at BOTTOM of detected range
// ═══════════════════════════════════════════════════════════
sz_lookback = input.int(20,    "Zone Lookback Bars",           minval=5,   maxval=100,        group="② S/D Zones")
sz_atrMult  = input.float(3.5, "Sideway ATR Multiplier",       minval=1.0, maxval=15.0, step=0.5, group="② S/D Zones")
sz_boxH     = input.float(0.6, "Zone Box Height (ATR ×)",      minval=0.1, maxval=3.0,  step=0.1, group="② S/D Zones")
sz_confirm  = input.int(2,     "Breakout Confirmation Bars",   minval=1,   maxval=5,          group="② S/D Zones")
sz_cooldown = input.int(10,    "Cooldown Bars After Breakout", minval=0,   maxval=50,         group="② S/D Zones")
sz_zoneClr  = input.color(color.new(#FFA726, 68), "Zone Color",       group="② S/D Zones")
sz_upClr    = input.color(#00E676,               "Arrow Up Color",   group="② S/D Zones")
sz_dnClr    = input.color(#FF1744,               "Arrow Down Color", group="② S/D Zones")

sz_atr   = ta.atr(sz_lookback)
sz_hi    = ta.highest(high, sz_lookback)
sz_lo    = ta.lowest(low,  sz_lookback)
sz_range = sz_hi - sz_lo
sz_isSW  = sz_range < sz_atr * sz_atrMult and sz_range > 0

var box   sz_resBox  = na
var box   sz_supBox  = na
var float sz_top     = na
var float sz_bot     = na
var bool  sz_open    = false
var int   sz_upCnt   = 0
var int   sz_dnCnt   = 0
var int   sz_coolCnt = 0

sz_coolCnt := math.max(0, sz_coolCnt - 1)

sz_hPx = sz_atr * sz_boxH

if enableZone and sz_isSW and not sz_open and sz_coolCnt == 0
    sz_top   := sz_hi
    sz_bot   := sz_lo
    sz_resBox := box.new(
         bar_index - sz_lookback, sz_hi - sz_hPx, bar_index, sz_hi,
         bgcolor      = sz_zoneClr,
         border_color = color.new(#FFA726, 20),
         border_width = 1)
    sz_supBox := box.new(
         bar_index - sz_lookback, sz_lo, bar_index, sz_lo + sz_hPx,
         bgcolor      = sz_zoneClr,
         border_color = color.new(#FFA726, 20),
         border_width = 1)
    sz_open  := true
    sz_upCnt := 0
    sz_dnCnt := 0

if sz_open
    if not na(sz_resBox)
        box.set_right(sz_resBox, bar_index)
    if not na(sz_supBox)
        box.set_right(sz_supBox, bar_index)

sz_brokeUp = sz_open and close > sz_top
sz_brokeDn = sz_open and close < sz_bot

if sz_brokeUp
    sz_upCnt := sz_upCnt + 1
    sz_dnCnt := 0
else if sz_brokeDn
    sz_dnCnt := sz_dnCnt + 1
    sz_upCnt := 0
else if sz_open
    sz_upCnt := 0
    sz_dnCnt := 0

sz_confirmedUp = enableZone and sz_brokeUp and sz_upCnt >= sz_confirm
sz_confirmedDn = enableZone and sz_brokeDn and sz_dnCnt >= sz_confirm

if (sz_confirmedUp or sz_confirmedDn) and sz_open
    if not na(sz_resBox)
        box.set_right(sz_resBox, bar_index)
    if not na(sz_supBox)
        box.set_right(sz_supBox, bar_index)
    sz_open    := false
    sz_coolCnt := sz_cooldown
    sz_upCnt   := 0
    sz_dnCnt   := 0

plotshape(sz_confirmedUp, "BreakUp",   shape.triangleup,   location.belowbar, color=sz_upClr, size=size.small)
plotshape(sz_confirmedDn, "BreakDown", shape.triangledown, location.abovebar, color=sz_dnClr, size=size.small)

if sz_confirmedUp
    label.new(bar_index, low  - sz_atr * 0.6, "▲ BREAKOUT",
         style=label.style_label_up, color=sz_upClr, textcolor=color.white, size=size.small)
if sz_confirmedDn
    label.new(bar_index, high + sz_atr * 0.6, "▼ BREAKDOWN",
         style=label.style_label_down, color=sz_dnClr, textcolor=color.white, size=size.small)

alertcondition(sz_confirmedUp, "② Breakout UP",    "Suite: Breakout UP")
alertcondition(sz_confirmedDn, "② Breakdown DOWN", "Suite: Breakdown DOWN")

// ═══════════════════════════════════════════════════════════
//  MODULE 3 — TRENDLINES (convergence-only)
//  Upper line = last 2 swing HIGHS (resistance)
//  Lower line = last 2 swing LOWS  (support)
//  Rule: draw ONLY when slope_resistance ≤ slope_support
//        (lines converge → triangle, or run parallel → channel)
//        Diverging / fanning outward → skip, draw nothing.
// ═══════════════════════════════════════════════════════════
tl_left   = input.int(10,    "Pivot Left Bars",     minval=3, maxval=50, group="③ Trendlines")
tl_right  = input.int(10,    "Pivot Right Bars",    minval=3, maxval=50, group="③ Trendlines")
tl_resClr = input.color(#EF9A9A, "Resistance Color", group="③ Trendlines")
tl_supClr = input.color(#80DEEA, "Support Color",    group="③ Trendlines")
tl_lw     = input.int(2,         "Line Width", minval=1, maxval=4, group="③ Trendlines")

tl_swHi = ta.pivothigh(high, tl_left, tl_right)
tl_swLo = ta.pivotlow(low,  tl_left, tl_right)

// Last 2 pivot highs
var float tl_hi1     = na
var int   tl_hi1_bar = na
var float tl_hi2     = na
var int   tl_hi2_bar = na

// Last 2 pivot lows
var float tl_lo1     = na
var int   tl_lo1_bar = na
var float tl_lo2     = na
var int   tl_lo2_bar = na

if not na(tl_swHi)
    tl_hi2     := tl_hi1
    tl_hi2_bar := tl_hi1_bar
    tl_hi1     := tl_swHi
    tl_hi1_bar := bar_index - tl_right

if not na(tl_swLo)
    tl_lo2     := tl_lo1
    tl_lo2_bar := tl_lo1_bar
    tl_lo1     := tl_swLo
    tl_lo1_bar := bar_index - tl_right

var line tl_resLine = na
var line tl_supLine = na

if enableLines
    line.delete(tl_resLine)
    line.delete(tl_supLine)
    tl_resLine := na
    tl_supLine := na

    tl_hasRes = not na(tl_hi1) and not na(tl_hi2) and tl_hi1_bar != tl_hi2_bar
    tl_hasSup = not na(tl_lo1) and not na(tl_lo2) and tl_lo1_bar != tl_lo2_bar

    // Need both sides to check convergence
    if tl_hasRes and tl_hasSup
        tl_sRes = (tl_hi1 - tl_hi2) / (tl_hi1_bar - tl_hi2_bar)  // resistance slope
        tl_sSup = (tl_lo1 - tl_lo2) / (tl_lo1_bar - tl_lo2_bar)  // support slope
        // Converge or parallel: resistance rises slower (or falls faster) than support
        // Diverge = resistance slope > support slope → skip
        if tl_sRes <= tl_sSup
            tl_resLine := line.new(
                 chart.point.from_index(tl_hi2_bar, tl_hi2),
                 chart.point.from_index(tl_hi1_bar, tl_hi1),
                 extend = extend.right,
                 color  = tl_resClr, width = tl_lw, style = line.style_dashed)
            tl_supLine := line.new(
                 chart.point.from_index(tl_lo2_bar, tl_lo2),
                 chart.point.from_index(tl_lo1_bar, tl_lo1),
                 extend = extend.right,
                 color  = tl_supClr, width = tl_lw, style = line.style_dashed)

// Touch alerts
tl_touchPct = close * 0.15 / 100
tl_nearRes  = false
tl_nearSup  = false

if enableLines and not na(tl_resLine)
    rv = line.get_price(tl_resLine, bar_index)
    if not na(rv)
        tl_nearRes := math.abs(close - rv) <= tl_touchPct

if enableLines and not na(tl_supLine)
    sv = line.get_price(tl_supLine, bar_index)
    if not na(sv)
        tl_nearSup := math.abs(close - sv) <= tl_touchPct

alertcondition(tl_nearSup, "③ Touch Support",    "Suite: Touching support trendline")
alertcondition(tl_nearRes, "③ Touch Resistance", "Suite: Touching resistance trendline")
