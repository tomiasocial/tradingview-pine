// ============================================================
// Auto Trendlines + S/D Zones | v0.3.1 | 2026-05-07
// Author: Project Owner
// Description: Auto-draws support/resistance trendlines from pivot swings
// ============================================================

//@version=6
indicator("Auto Trendlines [Suite]", overlay=true)

// ─── INPUTS ────────────────────────────────────────────────
pivotLeft   = input.int(10,    "Pivot Left Bars",     minval=3, maxval=50, group="Pivot Settings")
pivotRight  = input.int(10,    "Pivot Right Bars",    minval=3, maxval=50, group="Pivot Settings")
maxLines    = input.int(2,     "Max Trendlines Each", minval=1, maxval=5,  group="Pivot Settings")
showSDZones = input.bool(true, "Show S/D Zone Boxes",                      group="Display")

resColor    = input.color(#EF9A9A, "Resistance Line Color", group="Colors")
supColor    = input.color(#80DEEA, "Support Line Color",    group="Colors")
lineWidth   = input.int(2,         "Line Width", minval=1,  maxval=4,      group="Colors")

alertTouch  = input.bool(true,  "Alert on Price Touch",  group="Alerts")
touchBuffer = input.float(0.1,  "Touch Sensitivity %",   minval=0.01, maxval=1.0, step=0.01, group="Alerts")

// ─── PIVOT DETECTION ────────────────────────────────────────
swingHigh = ta.pivothigh(high, pivotLeft, pivotRight)
swingLow  = ta.pivotlow(low,  pivotLeft, pivotRight)

// ─── PIVOT STORAGE ──────────────────────────────────────────
var float[] shPrice = array.new_float(0)
var int[]   shBar   = array.new_int(0)
var float[] slPrice = array.new_float(0)
var int[]   slBar   = array.new_int(0)

if not na(swingHigh)
    array.push(shPrice, swingHigh)
    array.push(shBar,   bar_index - pivotRight)
    if array.size(shPrice) > maxLines + 1
        array.shift(shPrice)
        array.shift(shBar)

if not na(swingLow)
    array.push(slPrice, swingLow)
    array.push(slBar,   bar_index - pivotRight)
    if array.size(slPrice) > maxLines + 1
        array.shift(slPrice)
        array.shift(slBar)

// ─── LINE & BOX ARRAYS ──────────────────────────────────────
var line[] resLines = array.new_line(0)
var line[] supLines = array.new_line(0)
var box[]  sdBoxes  = array.new_box(0)

// Clear previous drawings each bar
for i = 0 to array.size(resLines) - 1
    line.delete(resLines[i])
array.clear(resLines)

for i = 0 to array.size(supLines) - 1
    line.delete(supLines[i])
array.clear(supLines)

for i = 0 to array.size(sdBoxes) - 1
    box.delete(sdBoxes[i])
array.clear(sdBoxes)

// ─── DRAW RESISTANCE TRENDLINES ─────────────────────────────
shSz = array.size(shPrice)
if shSz >= 2
    for i = shSz - 1 to math.max(shSz - maxLines, 1) by -1
        l = line.new(
             shBar[i - 1], shPrice[i - 1],
             shBar[i],     shPrice[i],
             extend      = extend.right,
             color       = resColor,
             width       = lineWidth,
             style       = line.style_dashed)
        array.push(resLines, l)
        if showSDZones
            pBar = shBar[i]
            pO   = open[bar_index  - pBar]
            pC   = close[bar_index - pBar]
            b    = box.new(pBar - 1, math.min(pO, pC), pBar + pivotRight, math.max(pO, pC),
                 bgcolor      = color.new(#FFA726, 80),
                 border_color = color.new(#FFA726, 30))
            array.push(sdBoxes, b)

// ─── DRAW SUPPORT TRENDLINES ────────────────────────────────
slSz = array.size(slPrice)
if slSz >= 2
    for i = slSz - 1 to math.max(slSz - maxLines, 1) by -1
        l = line.new(
             slBar[i - 1], slPrice[i - 1],
             slBar[i],     slPrice[i],
             extend      = extend.right,
             color       = supColor,
             width       = lineWidth,
             style       = line.style_dashed)
        array.push(supLines, l)
        if showSDZones
            pBar = slBar[i]
            pO   = open[bar_index  - pBar]
            pC   = close[bar_index - pBar]
            b    = box.new(pBar - 1, math.min(pO, pC), pBar + pivotRight, math.max(pO, pC),
                 bgcolor      = color.new(#FFA726, 80),
                 border_color = color.new(#FFA726, 30))
            array.push(sdBoxes, b)

// ─── TOUCH ALERTS ───────────────────────────────────────────
touchZone      = close * touchBuffer / 100
nearResistance = false
nearSupport    = false

if array.size(resLines) > 0
    rv = line.get_price(resLines[array.size(resLines) - 1], bar_index)
    if not na(rv)
        nearResistance := math.abs(close - rv) <= touchZone

if array.size(supLines) > 0
    sv = line.get_price(supLines[array.size(supLines) - 1], bar_index)
    if not na(sv)
        nearSupport := math.abs(close - sv) <= touchZone

// ─── ALERTS ────────────────────────────────────────────────
alertcondition(alertTouch and nearSupport,    "Touch Support",    "Auto Trendlines: Price touching support trendline")
alertcondition(alertTouch and nearResistance, "Touch Resistance", "Auto Trendlines: Price touching resistance trendline")
