// ============================================================
// Trend Candles | v0.1.1 | 2026-05-07
// Author: Project Owner
// Description: Color ALL candles by Supertrend direction (solid green/red)
// ============================================================

//@version=6
indicator("Trend Candles [Suite]", overlay=true, max_bars_back=500)

// ─── INPUTS ────────────────────────────────────────────────
atrPeriod    = input.int(10,   "ATR Period",        minval=3,   maxval=50,  group="Supertrend Settings")
atrMult      = input.float(2.0,"ATR Multiplier",    minval=0.5, maxval=5.0, step=0.1, group="Supertrend Settings")
confirmBars  = input.int(1,    "Confirmation Bars", minval=1,   maxval=5,   group="Supertrend Settings")

colorUp      = input.color(#00C853, "Uptrend Color",        group="Colors")
colorDown    = input.color(#FF1744, "Downtrend Color",      group="Colors")
showBaseline = input.bool(true,     "Show Supertrend Line", group="Display")

// ─── SUPERTREND CALCULATION ─────────────────────────────────
[stLine, stDir] = ta.supertrend(atrMult, atrPeriod)
// stDir: -1 = uptrend, +1 = downtrend (TradingView convention)

// ─── TREND CONFIRMATION (avoid whipsaw) ────────────────────
var int trendState = 0
var int barCount   = 0

rawDir = stDir == -1 ? 1 : -1  // normalize: 1=up, -1=down

if rawDir == trendState
    barCount := barCount + 1
else
    if barCount >= confirmBars
        trendState := rawDir
        barCount   := 1
    else
        barCount := barCount + 1

if trendState == 0
    trendState := rawDir
    barCount   := 1

isUptrend   = trendState == 1
isDowntrend = trendState == -1

// ─── CANDLE COLORING ────────────────────────────────────────
trendColor = isUptrend ? colorUp : colorDown

barcolor(trendColor)

plotcandle(
     open,  high,  low,  close,
     color       = trendColor,
     wickcolor   = trendColor,
     bordercolor = trendColor
 )

// ─── SUPERTREND BASELINE (optional) ────────────────────────
stColor = showBaseline ? (isUptrend ? color.new(colorUp, 60) : color.new(colorDown, 60)) : na
plot(showBaseline ? stLine : na, "Supertrend", color=stColor, linewidth=2)

// ─── ALERTS ────────────────────────────────────────────────
trendFlippedUp   = isUptrend   and not isUptrend[1]
trendFlippedDown = isDowntrend and not isDowntrend[1]

alertcondition(trendFlippedUp,   "Trend → UP",   "Trend Candles: Trend changed to UP")
alertcondition(trendFlippedDown, "Trend → DOWN", "Trend Candles: Trend changed to DOWN")
